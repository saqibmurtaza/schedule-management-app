# =============================================================================
# Neon PostgreSQL Database Configuration (Template)
# =============================================================================
# Copy this file to .env and replace placeholder values with your real ones

DB_POSTGRESDB_HOST=ep-round-shadow-an4xnq3r-pooler.c-6.us-east-1.aws.neon.tech

# Database Name
DB_POSTGRESDB_DATABASE=neondb

# Database User
DB_POSTGRESDB_USER=neondb_owner

# Database Password - REPLACE WITH YOUR ACTUAL PASSWORD
DB_POSTGRESDB_PASSWORD=your_actual_neon_password_here

# =============================================================================
# n8n Configuration
# =============================================================================

# Strong encryption key for n8n (minimum 32 characters)
# Generate using: openssl rand -hex 32
N8N_ENCRYPTION_KEY=your_very_strong_random_encryption_key_here

# Optional: n8n UI login credentials (change these)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_strong_password_here

/**
 * Note:
When setting up the project (on your laptop or for new developers):
cp infra/.env.example infra/.env
Then open infra/.env and replace the 
placeholders with real values.
 */