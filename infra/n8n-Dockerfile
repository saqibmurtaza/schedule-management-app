FROM n8nio/n8n:latest

# Copy workflows for automatic import on startup
COPY workflows/ /workflows/

# Create a startup script to handle import safely
RUN echo '#!/bin/sh\n\
n8n import:workflow --separate --input=/workflows/ || true\n\
exec n8n start\n' > /startup.sh && \
    chmod +x /startup.sh

# Use the startup script
CMD ["/startup.sh"]